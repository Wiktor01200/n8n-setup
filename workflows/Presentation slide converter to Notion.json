    {
      "parameters": {
        "jsCode": "const text = $input.first().json.message.content; // adjust to your field name\nconst sections = text.split(/(?=^#{1,3} )/m).filter(s => s.trim());\n\nreturn sections.map(section => ({ json: { section } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        0
      ],
      "id": "2fbf7031-8d74-49e2-a9db-dd16389199e7",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  const text = item.json.section;\n  if (text.length <= 1800) {\n    items.push({ json: { chunk: text } });\n    continue;\n  }\n  // split at newlines without cutting mid-sentence\n  const lines = text.split('\\n');\n  let current = '';\n  for (const line of lines) {\n    if ((current + '\\n' + line).length > 1800) {\n      if (current) items.push({ json: { chunk: current.trim() } });\n      current = line;\n    } else {\n      current += (current ? '\\n' : '') + line;\n    }\n  }\n  if (current) items.push({ json: { chunk: current.trim() } });\n}\n\nreturn items;"
      },
